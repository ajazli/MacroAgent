# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API key for Claude vision
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection string
# Local example:  postgresql://user:password@localhost:5432/fitbot
# Railway injects this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@localhost:5432/fitbot

# Telegram user ID of the instructor (get it from @userinfobot)
INSTRUCTOR_TELEGRAM_ID=123456789

# Webhook URL for production (leave blank for local polling mode)
# Railway example: https://fitbot-production.up.railway.app
# The bot will append /webhook/<token> automatically
WEBHOOK_URL=

# Port for the webhook server (Railway sets this automatically)
PORT=8443
